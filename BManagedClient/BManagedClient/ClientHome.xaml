<Page x:Class="BManagedClient.ClientHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Client Home" Background="{StaticResource Bg}">
    <StackPanel Margin="30">
        <TextBlock x:Name="welcome" Foreground="{StaticResource Cyan}" FontSize="28" FontWeight="Bold"/>
        <TextBlock Text="Use the web portal for full features. Logout when done."
                   Foreground="#888" Margin="0,8,0,16"/>
        <Button Content="Logout" Click="Logout_Click" Background="#555" Foreground="White"
                Width="120" HorizontalAlignment="Left" Height="32"/>
    </StackPanel>
</Page>
