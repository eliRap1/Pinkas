<Page x:Class="BManagedClient.Contracts"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Contracts" Background="{StaticResource Bg}">
    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{StaticResource EyebrowPill}">
                    <TextBlock Text="AGREEMENTS" Style="{StaticResource Eyebrow}"/>
                </Border>
                <TextBlock Text="Contracts." Style="{StaticResource DisplayLg}" Margin="0,10,0,0"/>
                <TextBlock Text="Sign first, invoice after." Style="{StaticResource Body}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="← Back" Click="Back_Click" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- New contract form -->
        <Border Grid.Row="1" Style="{StaticResource ShellCard}">
            <Border Style="{StaticResource CoreCard}" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CUSTOMER"  Style="{StaticResource InputLabel}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="PROJECT (OPTIONAL)" Style="{StaticResource InputLabel}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="ENGAGEMENT TITLE" Style="{StaticResource InputLabel}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="TOTAL AMOUNT" Style="{StaticResource InputLabel}" Margin="0,0,8,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="CURRENCY" Style="{StaticResource InputLabel}" Margin="0,0,0,4"/>

                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="customerCombo" Style="{StaticResource ModernCombo}"
                              DisplayMemberPath="BusinessName" SelectedValuePath="Id" Margin="0,0,8,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="projectCombo" Style="{StaticResource ModernCombo}"
                              DisplayMemberPath="Title" SelectedValuePath="Id" Margin="0,0,8,0"/>
                    <TextBox  Grid.Row="1" Grid.Column="2" x:Name="titleBox" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0"/>
                    <TextBox  Grid.Row="1" Grid.Column="3" x:Name="amountBox" Style="{StaticResource ModernTextBox}" Margin="0,0,8,0" Text="0"/>
                    <ComboBox Grid.Row="1" Grid.Column="4" x:Name="currencyCombo" Style="{StaticResource ModernCombo}">
                        <ComboBoxItem Content="ILS" IsSelected="True"/>
                        <ComboBoxItem Content="USD"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="5" Text="SCOPE OF WORK" Style="{StaticResource InputLabel}" Margin="0,12,0,4"/>
                    <TextBox  Grid.Row="3" Grid.ColumnSpan="5" x:Name="bodyBox"
                              Style="{StaticResource ModernTextBox}" Height="120"
                              AcceptsReturn="True" TextWrapping="Wrap"
                              VerticalContentAlignment="Top"/>
                </Grid>
            </Border>
        </Border>
        <Button Grid.Row="1" Content="➕ Create contract" Click="Create_Click" Style="{StaticResource MintButton}"
                HorizontalAlignment="Right" Margin="0,12,0,0"/>

        <!-- Contracts list -->
        <Border Grid.Row="2" Style="{StaticResource ShellCard}" Margin="0,16,0,0">
            <Border Style="{StaticResource CoreCard}" Padding="6">
                <ListView x:Name="contractsList" Background="Transparent" BorderThickness="0"
                          SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#"        DisplayMemberBinding="{Binding ContractNumber}" Width="120"/>
                            <GridViewColumn Header="Title"    DisplayMemberBinding="{Binding Title}"          Width="240"/>
                            <GridViewColumn Header="Status"   DisplayMemberBinding="{Binding Status}"         Width="100"/>
                            <GridViewColumn Header="Created"  DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="110"/>
                            <GridViewColumn Header="Total"    DisplayMemberBinding="{Binding TotalAmount, StringFormat=N2}"        Width="100"/>
                            <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}"       Width="70"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Border>

        <Border Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,12,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="📄 Save PDF"  Click="Pdf_Click"     Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                <Button Content="✓ Mark signed" Click="Sign_Click"  Style="{StaticResource MintButton}"   Margin="0,0,6,0"/>
                <Button Content="🗑 Delete"    Click="Delete_Click" Style="{StaticResource RoseButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
