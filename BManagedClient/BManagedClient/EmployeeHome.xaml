<Page x:Class="BManagedClient.EmployeeHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Employee Home" Background="{StaticResource Bg}">
    <StackPanel Margin="30">
        <TextBlock x:Name="welcome" Foreground="{StaticResource Green}" FontSize="32" FontWeight="Bold"/>
        <TextBlock Text="Your assigned projects" Foreground="#888" Margin="0,4,0,16"/>
        <ListView x:Name="projectsList" Background="{StaticResource Card}" Foreground="White"
                  BorderBrush="{StaticResource Green}" Height="380">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title"   DisplayMemberBinding="{Binding Title}"   Width="200"/>
                    <GridViewColumn Header="Status"  DisplayMemberBinding="{Binding Status}"  Width="120"/>
                    <GridViewColumn Header="Due"     DisplayMemberBinding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                    <GridViewColumn Header="Budget"  DisplayMemberBinding="{Binding TotalBudget, StringFormat=N2}" Width="100"/>
                    <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Button Content="Logout" Click="Logout_Click" Background="#555" Foreground="White" Margin="0,20,0,0" Height="32"/>
    </StackPanel>
</Page>
