<Page x:Class="BManagedClient.Expenses"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Expenses" Background="{StaticResource Bg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="Expenses" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Red}" HorizontalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource Card}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="catCombo" Grid.Column="0" Background="#0E1A2B" Foreground="White"
                          DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,4,0"/>
                <TextBox x:Name="vendorBox" Grid.Column="1" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0"/>
                <TextBox x:Name="amountBox" Grid.Column="2" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0" Text="0"/>
                <TextBox x:Name="vatBox"    Grid.Column="3" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0" Text="0"/>
                <Button Grid.Column="4" Content="➕ Log" Click="Add_Click" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource Red}" Foreground="White"/>
            </Grid>
        </Border>

        <ListView Grid.Row="2" x:Name="expList" Background="{StaticResource Card}"
                  Foreground="White" BorderBrush="{StaticResource Red}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Date"   DisplayMemberBinding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <GridViewColumn Header="Vendor" DisplayMemberBinding="{Binding Vendor}" Width="200"/>
                    <GridViewColumn Header="Amount" DisplayMemberBinding="{Binding Amount, StringFormat=N2}" Width="100"/>
                    <GridViewColumn Header="VAT"    DisplayMemberBinding="{Binding VatPaid, StringFormat=N2}" Width="80"/>
                    <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
