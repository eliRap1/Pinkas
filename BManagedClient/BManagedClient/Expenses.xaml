<Page x:Class="BManagedClient.Expenses"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Expenses" Background="{StaticResource Bg}">
    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Border Style="{StaticResource EyebrowPill}">
                    <TextBlock Text="OUTFLOWS" Style="{StaticResource Eyebrow}"/>
                </Border>
                <TextBlock Text="Expenses." Style="{StaticResource DisplayLg}" Margin="0,10,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="← Back" Click="Back_Click" Style="{StaticResource SecondaryButton}"
                    VerticalAlignment="Top"/>
        </Grid>

        <!-- Cheat sheet card explaining the two amounts -->
        <Border Grid.Row="1" Style="{StaticResource ShellCard}" Margin="0,0,0,12">
            <Border Style="{StaticResource CoreCard}" Padding="18,14">
                <StackPanel>
                    <TextBlock Text="HOW TO LOG AN EXPENSE" Style="{StaticResource Eyebrow}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}">
                        <Run FontWeight="SemiBold">Amount (gross)</Run>
                        <Run> — total you paid, VAT included. Example: a 117 ₪ supplier bill → enter 117.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}" Margin="0,4,0,0">
                        <Run FontWeight="SemiBold">VAT paid</Run>
                        <Run> — only the VAT portion you can later deduct. Example: from 118 → VAT = 18.
                              Click </Run>
                        <Run FontWeight="SemiBold">Auto VAT (18%)</Run>
                        <Run> to fill it from the gross amount automatically. Osek Patur cannot deduct VAT — VAT is forced to 0.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Border>

        <!-- Add expense form -->
        <Border Grid.Row="2" Style="{StaticResource ShellCard}">
            <Border Style="{StaticResource CoreCard}" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CATEGORY"      Style="{StaticResource InputLabel}" Margin="0,0,6,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="VENDOR"        Style="{StaticResource InputLabel}" Margin="0,0,6,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="AMOUNT (GROSS)" Style="{StaticResource InputLabel}" Margin="0,0,6,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="VAT PAID"      Style="{StaticResource InputLabel}" Margin="0,0,6,4"/>

                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="catCombo" Style="{StaticResource ModernCombo}"
                              DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,6,0"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="vendorBox" Style="{StaticResource ModernTextBox}" Margin="0,0,6,0"/>
                    <TextBox Grid.Row="1" Grid.Column="2" x:Name="amountBox" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,6,0" Text="0" TextChanged="Amount_Changed"
                             ToolTip="Total you paid the supplier, VAT included"/>
                    <TextBox Grid.Row="1" Grid.Column="3" x:Name="vatBox" Style="{StaticResource ModernTextBox}"
                             Margin="0,0,6,0" Text="0"
                             ToolTip="VAT portion only — the part you can deduct"/>
                    <Button  Grid.Row="1" Grid.Column="4" Content="Auto VAT (18%)" Click="AutoVat_Click"
                             Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                             ToolTip="Fill VAT = Amount × 18 ÷ 118 (Israeli standard, since 2025). Forced 0 for Osek Patur."/>
                    <Button  Grid.Row="1" Grid.Column="5" Content="➕ Log expense" Click="Add_Click" Style="{StaticResource RoseButton}"/>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ShellCard}" Margin="0,12,0,0">
            <Border Style="{StaticResource CoreCard}" Padding="6">
                <ListView x:Name="expList" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date"         DisplayMemberBinding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="120"/>
                            <GridViewColumn Header="Vendor"       DisplayMemberBinding="{Binding Vendor}"    Width="240"/>
                            <GridViewColumn Header="Amount gross" DisplayMemberBinding="{Binding Amount, StringFormat=N2}"  Width="120"/>
                            <GridViewColumn Header="VAT paid"     DisplayMemberBinding="{Binding VatPaid, StringFormat=N2}" Width="100"/>
                            <GridViewColumn Header="Currency"     DisplayMemberBinding="{Binding Currency}" Width="80"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Border>
    </Grid>
</Page>
