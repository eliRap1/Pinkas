<Page x:Class="BManagedClient.ForgotPassword"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reset password" Background="{StaticResource Bg}">
    <Grid>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="440">
            <Border Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="36,30">
                    <StackPanel>
                        <Border Style="{StaticResource EyebrowPill}" HorizontalAlignment="Center">
                            <TextBlock Text="RESET" Style="{StaticResource Eyebrow}"/>
                        </Border>
                        <TextBlock Text="Forgot password?" Style="{StaticResource DisplayLg}"
                                   HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                                   Style="{StaticResource Body}" Margin="0,0,0,24">
                            Enter your username. Owner will reset it manually — check your email or ask them.
                        </TextBlock>

                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="usernameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,18"/>

                        <Button Content="Request reset" Click="Request_Click"
                                Style="{StaticResource PrimaryButton}" Height="42"/>
                        <Button Content="← Back to login" Click="Back_Click"
                                Style="{StaticResource GhostButton}" Margin="0,12,0,0"/>

                        <TextBlock x:Name="status" HorizontalAlignment="Center"
                                   Margin="0,12,0,0" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
