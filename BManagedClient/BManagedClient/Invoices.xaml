<Page x:Class="BManagedClient.Invoices"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Invoices" Background="{StaticResource Bg}">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="Invoices" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Cyan}" HorizontalAlignment="Center"/>
        </Grid>

        <ListView Grid.Row="1" Grid.Column="0" x:Name="invoiceList" Background="{StaticResource Card}"
                  Foreground="White" BorderBrush="{StaticResource Cyan}" SelectionMode="Single"
                  SelectionChanged="Inv_Selected" Margin="0,0,12,0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#" DisplayMemberBinding="{Binding InvoiceNumber}" Width="120"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="80"/>
                    <GridViewColumn Header="Total" DisplayMemberBinding="{Binding Total, StringFormat=N0}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Card}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="newCustomer" Grid.Column="0" Background="#0E1A2B" Foreground="White"
                              DisplayMemberPath="BusinessName" SelectedValuePath="Id" Margin="0,0,8,0"/>
                    <ComboBox x:Name="newCurrency" Grid.Column="1" Width="80" Background="#0E1A2B" Foreground="White" Margin="0,0,8,0">
                        <ComboBoxItem Content="ILS" IsSelected="True"/>
                        <ComboBoxItem Content="USD"/>
                    </ComboBox>
                    <Button Grid.Column="2" Content="➕ New invoice" Click="Create_Click"
                            Style="{StaticResource PrimaryButton}" Background="{StaticResource Green}"/>
                </Grid>
            </Border>

            <ListView Grid.Row="1" x:Name="lineList" Background="{StaticResource Card}"
                      Foreground="White" BorderBrush="{StaticResource Cyan}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="260"/>
                        <GridViewColumn Header="Qty"   DisplayMemberBinding="{Binding Quantity}"  Width="60"/>
                        <GridViewColumn Header="Unit"  DisplayMemberBinding="{Binding UnitPrice, StringFormat=N2}" Width="80"/>
                        <GridViewColumn Header="Total" DisplayMemberBinding="{Binding LineTotal, StringFormat=N2}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Border Grid.Row="2" Background="{StaticResource Card}" CornerRadius="8" Padding="12" Margin="0,12,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="lineDesc" Grid.Column="0" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0"/>
                    <TextBox x:Name="lineQty"  Grid.Column="1" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0" Text="1"/>
                    <TextBox x:Name="lineUnit" Grid.Column="2" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,4,0" Text="0"/>
                    <Button Grid.Column="3" Content="+ Line" Click="AddLine_Click"
                            Style="{StaticResource PrimaryButton}"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="totalsText" Foreground="White" FontSize="14" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <Button Content="Mark Sent" Click="Sent_Click" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource Orange}" Margin="0,0,6,0"/>
                <Button Content="Mark Paid" Click="Paid_Click" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource Green}" Margin="0,0,6,0"/>
                <Button Content="📄 Save PDF" Click="Pdf_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
