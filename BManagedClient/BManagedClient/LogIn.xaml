<Page x:Class="BManagedClient.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BManagedClient"
      Title="Sign in" Background="{StaticResource Bg}">
    <Grid>
        <Frame x:Name="page" Panel.ZIndex="100" NavigationUIVisibility="Hidden"
               Background="{StaticResource Bg}" Visibility="Collapsed"/>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
            <Border Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="36,30">
                    <StackPanel>
                        <Border Style="{StaticResource EyebrowPill}" HorizontalAlignment="Center">
                            <TextBlock Text="WORKSPACE" Style="{StaticResource Eyebrow}"/>
                        </Border>

                        <TextBlock Text="Welcome back" Style="{StaticResource DisplayLg}"
                                   HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="Run your business — calmly."
                                   Style="{StaticResource Body}" HorizontalAlignment="Center"
                                   Margin="0,0,0,28"/>

                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabel}"/>
                        <TextBox x:Name="username" Style="{StaticResource ModernTextBox}" Margin="0,0,0,14">
                            <TextBox.Text>
                                <Binding Path="Username" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:MinLenth/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="PASSWORD" Style="{StaticResource InputLabel}"/>
                        <PasswordBox x:Name="pass" Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,22"/>

                        <Button Content="Sign in" Style="{StaticResource PrimaryButton}"
                                Click="signIn_Click" Height="42"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <Button Content="Create account" Click="signUp_Click"
                                    Style="{StaticResource GhostButton}"/>
                            <TextBlock Text=" · " Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                            <Button Content="Forgot password" Click="forgot_Click"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>

                        <TextBlock x:Name="error" Foreground="{StaticResource Rose}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"
                                   Visibility="Collapsed" FontSize="12"/>

                        <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center"
                                   Margin="0,18,0,0" TextAlignment="Center">
                            Seeded admin: <Run FontWeight="SemiBold">admin</Run> / <Run FontWeight="SemiBold">admin1234</Run>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Page>
