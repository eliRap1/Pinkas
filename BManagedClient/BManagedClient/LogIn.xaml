<Page x:Class="BManagedClient.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BManagedClient"
      Title="LogIn" Background="{StaticResource Bg}">
    <Grid>
        <Frame x:Name="page" Panel.ZIndex="100"/>
        <Border Style="{StaticResource CardBorder}" MaxWidth="380" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="B-Managed" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource Cyan}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Small-Business Manager" FontSize="13"
                           Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Username" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="username" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Height="34" Padding="8" Margin="0,0,0,12">
                    <TextBox.Text>
                        <Binding Path="Username" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <local:MinLenth/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <TextBlock Text="Password" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                <PasswordBox x:Name="pass" Background="#0E1A2B" Foreground="White"
                             BorderBrush="{StaticResource Cyan}" Height="34" Padding="8" Margin="0,0,0,18"/>

                <Button Content="Sign In" Style="{StaticResource PrimaryButton}"
                        Click="signIn_Click" Height="38"/>
                <TextBlock x:Name="error" Foreground="{StaticResource Red}"
                           HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
