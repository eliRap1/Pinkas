<Page x:Class="BManagedClient.ManageUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Manage Users" Background="{StaticResource Bg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6"/>
            <TextBlock Grid.Column="1" Text="Manage Users" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Red}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" x:Name="pendingBadge" Foreground="{StaticResource Orange}"
                       FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>

        <ListView Grid.Row="1" x:Name="userList" Background="{StaticResource Card}"
                  Foreground="White" BorderBrush="{StaticResource Cyan}" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Username" DisplayMemberBinding="{Binding Username}" Width="160"/>
                    <GridViewColumn Header="Role"     DisplayMemberBinding="{Binding Role}"     Width="100"/>
                    <GridViewColumn Header="Email"    DisplayMemberBinding="{Binding Email}"    Width="200"/>
                    <GridViewColumn Header="Phone"    DisplayMemberBinding="{Binding Phone}"    Width="120"/>
                    <GridViewColumn Header="Active"   DisplayMemberBinding="{Binding IsActive}" Width="60"/>
                    <GridViewColumn Header="Created"  DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ComboBox x:Name="roleCombo" Width="120" Background="#0E1A2B" Foreground="White" Margin="0,0,8,0">
                <ComboBoxItem Content="Owner"/>
                <ComboBoxItem Content="Employee"/>
                <ComboBoxItem Content="Client"/>
            </ComboBox>
            <Button Content="Set Role" Click="SetRole_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
            <Button Content="Approve / Block" Click="Toggle_Click"
                    Style="{StaticResource PrimaryButton}" Background="{StaticResource Orange}" Margin="0,0,6,0"/>
            <Button Content="Reset PW" Click="ResetPw_Click"
                    Style="{StaticResource PrimaryButton}" Background="#888" Margin="0,0,6,0"/>
            <Button Content="Delete" Click="Delete_Click"
                    Style="{StaticResource PrimaryButton}" Background="{StaticResource Red}"/>
        </StackPanel>
    </Grid>
</Page>
