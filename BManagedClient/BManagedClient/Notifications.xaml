<Page x:Class="BManagedClient.Notifications"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Notifications" Background="{StaticResource Bg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6"/>
            <TextBlock Grid.Column="1" Text="Notifications" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Cyan}" HorizontalAlignment="Center"/>
            <Button Grid.Column="2" Content="✓ Mark all read" Click="MarkAll_Click"
                    Style="{StaticResource PrimaryButton}" Background="#888"/>
        </Grid>

        <ListView Grid.Row="1" x:Name="notifList" Background="{StaticResource Card}"
                  Foreground="White" BorderBrush="{StaticResource Cyan}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title"   DisplayMemberBinding="{Binding Title}"   Width="220"/>
                    <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="380"/>
                    <GridViewColumn Header="Type"    DisplayMemberBinding="{Binding NotificationType}" Width="100"/>
                    <GridViewColumn Header="When"    DisplayMemberBinding="{Binding CreatedAt, StringFormat=dd/MM HH:mm}" Width="100"/>
                    <GridViewColumn Header="Read"    DisplayMemberBinding="{Binding IsRead}"   Width="60"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
