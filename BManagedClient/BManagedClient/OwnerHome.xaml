<Page x:Class="BManagedClient.OwnerHome"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Owner Home" Background="{StaticResource Bg}">
    <Grid>
        <Frame x:Name="page" Panel.ZIndex="100" NavigationUIVisibility="Hidden"
               Background="{StaticResource Bg}" Visibility="Collapsed"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28">

                <!-- Header -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource EyebrowPill}">
                            <TextBlock Text="OWNER" Style="{StaticResource Eyebrow}"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="Hi, " Style="{StaticResource DisplayLg}"/>
                            <TextBlock x:Name="welcome" Style="{StaticResource DisplayLg}" Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="." Style="{StaticResource DisplayLg}"/>
                        </StackPanel>
                        <TextBlock Text="Your money, in motion." Style="{StaticResource Body}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Click="Notifications_Click" Style="{StaticResource NavButton}"
                            ToolTip="Notifications" VerticalAlignment="Top">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔔" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Notifications"/>
                            </StackPanel>
                            <Border x:Name="notifBadge" Background="{StaticResource Rose}"
                                    CornerRadius="999" Padding="6,1" Margin="-12,-8,0,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="notifBadgeText" Text="0" Foreground="White"
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Button>
                    <Button Grid.Column="2" Content="Logout" Click="Logout_Click"
                            Style="{StaticResource PrimaryButton}" VerticalAlignment="Top"/>
                </Grid>

                <!-- Stat cards -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ShellCard}" Margin="0,0,8,0">
                        <Border Style="{StaticResource CoreCard}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="CUSTOMERS" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="customersCount" Text="0" Style="{StaticResource Display}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ShellCard}" Margin="4,0">
                        <Border Style="{StaticResource CoreCard}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="ACTIVE PROJECTS" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="activeProjects" Text="0" Style="{StaticResource Display}"
                                           Foreground="{StaticResource Mint}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ShellCard}" Margin="4,0">
                        <Border Style="{StaticResource CoreCard}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="UNPAID" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="unpaidCount" Text="0" Style="{StaticResource Display}"
                                           Foreground="{StaticResource Amber}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource ShellCard}" Margin="8,0,0,0">
                        <Border Style="{StaticResource CoreCard}" Padding="20">
                            <StackPanel>
                                <TextBlock Text="OVERDUE" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="overdueCount" Text="0" Style="{StaticResource Display}"
                                           Foreground="{StaticResource Rose}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>

                <!-- Quick actions grid -->
                <Border Style="{StaticResource ShellCard}">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="QUICK ACTIONS" Style="{StaticResource Eyebrow}" Margin="0,0,0,14"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" Content="👥  Customers"
                                        Click="Customers_Click" Style="{StaticResource PrimaryButton}"
                                        Height="56" Margin="4"/>
                                <Button Grid.Row="0" Grid.Column="1" Content="📁  Projects"
                                        Click="Projects_Click" Style="{StaticResource SecondaryButton}"
                                        Height="56" Margin="4"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="📜  Contracts"
                                        Click="Contracts_Click" Style="{StaticResource AmberButton}"
                                        Height="56" Margin="4"/>
                                <Button Grid.Row="1" Grid.Column="0" Content="🧾  Invoices"
                                        Click="Invoices_Click" Style="{StaticResource AmberButton}"
                                        Height="56" Margin="4"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="💸  Expenses"
                                        Click="Expenses_Click" Style="{StaticResource RoseButton}"
                                        Height="56" Margin="4"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="📊  Reports"
                                        Click="Reports_Click" Style="{StaticResource MintButton}"
                                        Height="56" Margin="4"/>
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="👥  Users"
                                        Click="Settings_Click" Style="{StaticResource SecondaryButton}"
                                        Height="56" Margin="4"
                                        ToolTip="Manage users, approve sign-ups, reset passwords"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
