<Page x:Class="BManagedClient.Projects"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Projects" Background="{StaticResource Bg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6" Cursor="Hand"/>
            <TextBlock Grid.Column="1" Text="Projects" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Cyan}" HorizontalAlignment="Center"/>
            <ComboBox Grid.Column="2" x:Name="statusFilter" Width="160" Background="{StaticResource Card}"
                      Foreground="White" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="AwaitingPayment"/>
                <ComboBoxItem Content="Done"/>
                <ComboBoxItem Content="Cancelled"/>
            </ComboBox>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource Card}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="customerCombo" Grid.Column="0" Margin="0,0,8,0" Background="#0E1A2B" Foreground="White"
                          DisplayMemberPath="BusinessName" SelectedValuePath="Id"/>
                <TextBox x:Name="titleBox" Grid.Column="1" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Margin="0,0,8,0" Padding="8" Text=""/>
                <TextBox x:Name="budgetBox" Grid.Column="2" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Margin="0,0,8,0" Padding="8" Text="0"/>
                <Button Grid.Column="3" Content="➕ Add" Click="Add_Click" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource Green}" Foreground="White"/>
            </Grid>
        </Border>

        <ListView Grid.Row="2" x:Name="projectsList" Background="{StaticResource Card}"
                  Foreground="White" BorderBrush="{StaticResource Cyan}" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Title"  DisplayMemberBinding="{Binding Title}"  Width="240"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="140"/>
                    <GridViewColumn Header="Due"    DisplayMemberBinding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="120"/>
                    <GridViewColumn Header="Budget" DisplayMemberBinding="{Binding TotalBudget, StringFormat=N2}" Width="100"/>
                    <GridViewColumn Header="Currency" DisplayMemberBinding="{Binding Currency}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
