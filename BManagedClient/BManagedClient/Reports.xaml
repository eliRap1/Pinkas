<Page x:Class="BManagedClient.Reports"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reports" Background="{StaticResource Bg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back" Click="Back_Click" Background="Transparent"
                    Foreground="{StaticResource Cyan}" BorderBrush="{StaticResource Cyan}" Padding="12,6"/>
            <TextBlock Grid.Column="1" Text="Reports" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Green}" HorizontalAlignment="Center"/>
            <ComboBox Grid.Column="2" x:Name="yearCombo" Width="80" Background="{StaticResource Card}"
                      Foreground="White" SelectionChanged="Filter_Changed" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="3" x:Name="monthCombo" Width="80" Background="{StaticResource Card}"
                      Foreground="White" SelectionChanged="Filter_Changed" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="4" x:Name="curCombo" Width="80" Background="{StaticResource Card}"
                      Foreground="White" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="ILS" IsSelected="True"/>
                <ComboBoxItem Content="USD"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="vatColl" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Cyan}" HorizontalAlignment="Center"/>
                    <TextBlock Text="VAT collected" FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" BorderBrush="{StaticResource Green}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="vatPaid" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Green}" HorizontalAlignment="Center"/>
                    <TextBlock Text="VAT paid" FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" BorderBrush="{StaticResource Red}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="vatDue" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Red}" HorizontalAlignment="Center"/>
                    <TextBlock Text="VAT due" FontSize="11" Foreground="#888"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Top customers by revenue" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Cyan}" Margin="0,0,0,8"/>
                <ListView x:Name="topCustomers" Background="Transparent" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding BusinessName}" Width="260"/>
                            <GridViewColumn Header="Invoiced" DisplayMemberBinding="{Binding TotalInvoiced, StringFormat=N0}" Width="120"/>
                            <GridViewColumn Header="Paid"     DisplayMemberBinding="{Binding TotalPaid,     StringFormat=N0}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Expense breakdown" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Red}" Margin="0,0,0,8"/>
                <ListView x:Name="breakdown" Background="Transparent" Foreground="White" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding CategoryName}" Width="200"/>
                            <GridViewColumn Header="Total"    DisplayMemberBinding="{Binding Total, StringFormat=N2}" Width="120"/>
                            <GridViewColumn Header="VAT-deductible" DisplayMemberBinding="{Binding IsVatDeductible}" Width="120"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Page>
