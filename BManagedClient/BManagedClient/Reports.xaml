<Page x:Class="BManagedClient.Reports"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reports" Background="{StaticResource Bg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <Border Style="{StaticResource EyebrowPill}">
                        <TextBlock Text="REPORTS" Style="{StaticResource Eyebrow}"/>
                    </Border>
                    <TextBlock Text="Numbers, on tap." Style="{StaticResource DisplayLg}" Margin="0,10,0,0"/>
                </StackPanel>
                <ComboBox Grid.Column="1" x:Name="yearCombo"  Width="90"  Style="{StaticResource ModernCombo}"
                          SelectionChanged="Filter_Changed" Margin="0,0,8,0" VerticalAlignment="Top"/>
                <ComboBox Grid.Column="2" x:Name="monthCombo" Width="90"  Style="{StaticResource ModernCombo}"
                          SelectionChanged="Filter_Changed" Margin="0,0,8,0" VerticalAlignment="Top"/>
                <ComboBox Grid.Column="3" x:Name="curCombo"   Width="80"  Style="{StaticResource ModernCombo}"
                          SelectionChanged="Filter_Changed" Margin="0,0,8,0" VerticalAlignment="Top">
                    <ComboBoxItem Content="ILS" IsSelected="True"/>
                    <ComboBoxItem Content="USD"/>
                </ComboBox>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="📤 Export CSV" Click="ExportCsv_Click"
                            Style="{StaticResource MintButton}" Margin="0,0,8,0"/>
                    <Button Content="← Back" Click="Back_Click" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>

            <!-- VAT cards -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource ShellCard}" Margin="0,0,8,0">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="VAT COLLECTED" Style="{StaticResource Eyebrow}"/>
                            <TextBlock x:Name="vatColl" Text="0" Style="{StaticResource Display}" FontSize="42" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource ShellCard}" Margin="4,0">
                    <Border Style="{StaticResource CoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="VAT PAID" Style="{StaticResource Eyebrow}"/>
                            <TextBlock x:Name="vatPaid" Text="0" Style="{StaticResource Display}" FontSize="42"
                                       Foreground="{StaticResource Mint}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource ShellCard}" Margin="8,0,0,0">
                    <Border Style="{StaticResource DarkCoreCard}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="VAT DUE" Style="{StaticResource Eyebrow}" Foreground="#88FFFFFF"/>
                            <TextBlock x:Name="vatDue" Text="0" Style="{StaticResource Display}" FontSize="42"
                                       Foreground="White" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>

            <!-- P&L (year) + Tax -->
            <Border Grid.Row="2" Style="{StaticResource ShellCard}" Margin="0,0,0,16">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="PROFIT &amp; LOSS (YEAR)" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="INCOME (YR)" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="plIncome" Text="0" Style="{StaticResource Display}" FontSize="26"
                                           Foreground="{StaticResource Mint}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="EXPENSES (YR)" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="plExpenses" Text="0" Style="{StaticResource Display}" FontSize="26"
                                           Foreground="{StaticResource Rose}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="GROSS PROFIT" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="plProfit" Text="0" Style="{StaticResource Display}" FontSize="26" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="8,0">
                                <TextBlock Text="INCOME TAX" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="plTax" Text="0" Style="{StaticResource Display}" FontSize="26"
                                           Foreground="{StaticResource Amber}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="plTaxBase" Style="{StaticResource Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Margin="8,0,0,0">
                                <TextBlock Text="NET (YR)" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="plNet" Text="0" Style="{StaticResource Display}" FontSize="26"
                                           Foreground="{StaticResource Mint}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="taxNote" Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- KPI scorecard -->
            <Border Grid.Row="3" Style="{StaticResource ShellCard}" Margin="0,0,0,16">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="OPERATING KPIs" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="OUTSTANDING TOTAL" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="kpiOutstanding" Text="0" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                                <TextBlock x:Name="kpiAging" Style="{StaticResource Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="AVG DAYS TO PAYMENT" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="kpiDays" Text="—" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                                <TextBlock x:Name="kpiOnTime" Style="{StaticResource Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="TOP CUSTOMER SHARE" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="kpiTopShare" Text="—" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                                <TextBlock x:Name="kpiTopName"  Style="{StaticResource Caption}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="AVG MONTHLY PROFIT" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="kpiMonthlyProfit" Text="0" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                                <TextBlock x:Name="kpiRunway" Style="{StaticResource Caption}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Loan summary -->
            <Border Grid.Row="4" x:Name="loanCard" Style="{StaticResource ShellCard}" Margin="0,0,0,16" Visibility="Collapsed">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LOANS (קרן)" Style="{StaticResource Eyebrow}"/>
                            <Button Grid.Column="1" Content="→ Manage loans" Click="OpenLoans_Click"
                                    Style="{StaticResource AmberButton}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="ACTIVE" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="loanCount" Text="0" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="OUTSTANDING" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="loanRemaining" Text="0" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0">
                                <TextBlock Text="MONTHLY" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="loanMonthly" Text="0" Style="{StaticResource Display}" FontSize="22"
                                           Foreground="{StaticResource Amber}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                <TextBlock Text="DEBT-SERVICE RATIO" Style="{StaticResource Eyebrow}"/>
                                <TextBlock x:Name="loanDsr" Text="—" Style="{StaticResource Display}" FontSize="22" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Top customers -->
            <Border Grid.Row="5" Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="TOP CUSTOMERS BY REVENUE" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <ListView x:Name="topCustomers" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding BusinessName}"  Width="280"/>
                                    <GridViewColumn Header="Invoiced" DisplayMemberBinding="{Binding TotalInvoiced, StringFormat=N0}" Width="140"/>
                                    <GridViewColumn Header="Paid"     DisplayMemberBinding="{Binding TotalPaid,     StringFormat=N0}" Width="140"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Expense breakdown -->
            <Border Grid.Row="6" Style="{StaticResource ShellCard}">
                <Border Style="{StaticResource CoreCard}" Padding="22">
                    <StackPanel>
                        <TextBlock Text="EXPENSE BREAKDOWN" Style="{StaticResource Eyebrow}" Margin="0,0,0,12"/>
                        <ListView x:Name="breakdown" Background="Transparent" BorderThickness="0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Category"        DisplayMemberBinding="{Binding CategoryName}" Width="220"/>
                                    <GridViewColumn Header="Total"           DisplayMemberBinding="{Binding Total, StringFormat=N2}" Width="140"/>
                                    <GridViewColumn Header="VAT-deductible"  DisplayMemberBinding="{Binding IsVatDeductible}" Width="140"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
