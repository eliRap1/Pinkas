<Page x:Class="BManagedClient.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{StaticResource Bg}">
    <Grid Margin="20" MaxWidth="600" HorizontalAlignment="Center">
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Cyan}" Margin="0,0,0,16"/>

                <TextBlock Text="Email" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="emailBox" Background="#0E1A2B" Foreground="White" BorderBrush="{StaticResource Cyan}" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Phone" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="phoneBox" Background="#0E1A2B" Foreground="White" BorderBrush="{StaticResource Cyan}" Padding="6" Margin="0,0,0,12"/>

                <TextBlock Text="Preferred currency" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="curCombo" Background="#0E1A2B" Foreground="White" Margin="0,0,0,16">
                    <ComboBoxItem Content="ILS"/>
                    <ComboBoxItem Content="USD"/>
                </ComboBox>

                <Button Content="Save profile" Click="Save_Click" Style="{StaticResource PrimaryButton}" Height="36" Margin="0,0,0,8"/>

                <Separator Margin="0,12"/>
                <TextBlock Text="Change password" Foreground="{StaticResource Orange}" FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                <PasswordBox x:Name="newPass" Background="#0E1A2B" Foreground="White" Padding="6" Margin="0,0,0,8"/>
                <Button Content="Update password" Click="UpdatePass_Click" Style="{StaticResource PrimaryButton}" Background="{StaticResource Orange}" Height="32"/>

                <TextBlock x:Name="status" Margin="0,16,0,0" Foreground="#888"/>
                <Button Content="← Back" Click="Back_Click" Background="Transparent" Foreground="{StaticResource Cyan}" Margin="0,16,0,0" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
