<Page x:Class="BManagedClient.SignUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BManagedClient"
      Title="SignUp" Background="{StaticResource Bg}">
    <Grid>
        <Border Style="{StaticResource CardBorder}" MaxWidth="420" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Create account" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource Cyan}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Self-register as a Client. Owner can promote later."
                           FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Username" Foreground="#aaa" FontSize="11" Margin="0,0,0,3"/>
                <TextBox x:Name="usernameBox" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Height="32" Padding="6" Margin="0,0,0,10">
                    <TextBox.Text>
                        <Binding Path="Username" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules><local:MinLenth/></Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <TextBlock Text="Password" Foreground="#aaa" FontSize="11" Margin="0,0,0,3"/>
                <PasswordBox x:Name="passwordBox" Background="#0E1A2B" Foreground="White"
                             BorderBrush="{StaticResource Cyan}" Height="32" Padding="6" Margin="0,0,0,10"/>

                <TextBlock Text="Email" Foreground="#aaa" FontSize="11" Margin="0,0,0,3"/>
                <TextBox x:Name="emailBox" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Height="32" Padding="6" Margin="0,0,0,10">
                    <TextBox.Text>
                        <Binding Path="Email" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules><local:EmailRule/></Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <TextBlock Text="Phone" Foreground="#aaa" FontSize="11" Margin="0,0,0,3"/>
                <TextBox x:Name="phoneBox" Background="#0E1A2B" Foreground="White"
                         BorderBrush="{StaticResource Cyan}" Height="32" Padding="6" Margin="0,0,0,10">
                    <TextBox.Text>
                        <Binding Path="Phone" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules><local:PhoneRule/></Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>

                <TextBlock Text="Preferred currency" Foreground="#aaa" FontSize="11" Margin="0,0,0,3"/>
                <ComboBox x:Name="curBox" Background="#0E1A2B" Foreground="White" Margin="0,0,0,16">
                    <ComboBoxItem Content="ILS" IsSelected="True"/>
                    <ComboBoxItem Content="USD"/>
                </ComboBox>

                <Button Content="Create account" Click="Create_Click"
                        Style="{StaticResource PrimaryButton}" Height="36" Margin="0,0,0,8"/>
                <Button Content="← Back to login" Click="Back_Click" Background="Transparent"
                        Foreground="{StaticResource Cyan}" BorderThickness="0" Cursor="Hand"/>

                <TextBlock x:Name="status" Foreground="{StaticResource Red}"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
