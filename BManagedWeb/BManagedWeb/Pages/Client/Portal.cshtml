@page
@model BManagedWeb.Pages.Client.PortalModel
@{
    ViewData["Title"] = "My Portal";
}

<div class="reveal mb-12">
    <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Portal","פורטל")</span>
    <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">
        @L.T(HttpContext,"Welcome,","ברוך הבא,") @Model.Username.<br/><span class="text-ink/40">@L.T(HttpContext,"Your invoices.","החשבוניות שלך.")</span>
    </h1>
</div>

<section class="reveal grid grid-cols-1 md:grid-cols-2 gap-4">
    @foreach (var inv in Model.Invoices)
    {
        var color = inv.Status == "Paid" ? "mint" : (inv.Status == "Overdue" ? "rose" : "amber");
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset">
                <div class="flex justify-between items-start">
                    <div>
                        <span class="pill text-ink/40">@inv.InvoiceNumber</span>
                        <div class="display text-2xl font-semibold mt-1">@inv.Total.ToString("N2") <span class="text-ink/40 text-sm">@inv.Currency</span></div>
                        <div class="text-xs text-ink/40 mt-1">@L.T(HttpContext,"Due","יעד") @inv.DueDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="pill rounded-full px-2 py-0.5 bg-@(color)/10 text-@(color) border border-@(color)/20">@inv.Status</div>
                </div>
            </div>
        </div>
    }
    @if (Model.Invoices.Count == 0)
    {
        <div class="md:col-span-2 text-center py-20 text-ink/40">@L.T(HttpContext,"No invoices yet.","אין חשבוניות עדיין.")</div>
    }
</section>
