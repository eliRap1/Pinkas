@page
@model BManagedWeb.Pages.Employee.ProjectsModel
@{ ViewData["Title"] = "My projects"; }

<div class="reveal mb-12">
    <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">Assigned</span>
    <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">Your projects.</h1>
</div>

<section class="reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var p in Model.Projects)
    {
        var color = p.Status switch { "Done" => "mint", "AwaitingPayment" => "amber", _ => "accent" };
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                <span class="pill text-ink/40">#@p.Id</span>
                <div class="display text-xl font-semibold mt-1">@p.Title</div>
                <p class="text-sm text-ink/50 mt-2">@p.Description</p>
                <div class="text-xs text-ink/40 mt-3">Due @(p.DueDate?.ToString("dd MMM") ?? "—")</div>
                <div class="pill rounded-full px-2 py-0.5 mt-3 inline-block bg-@(color)/10 text-@(color) border border-@(color)/20">@p.Status</div>
            </div>
        </div>
    }
    @if (Model.Projects.Count == 0)
    { <div class="md:col-span-3 text-center py-20 text-ink/40">Nothing assigned yet.</div> }
</section>
