@page
@model BManagedWeb.Pages.ForgotPasswordModel
@{ ViewData["Title"] = "Reset password"; }

<section class="reveal min-h-[80dvh] grid place-items-center">
    <div class="w-full max-w-md">
        <div class="flex justify-center mb-6">
            <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Reset","איפוס")</span>
        </div>
        <h1 class="display text-5xl md:text-6xl font-bold text-center text-ink mb-2">
            @L.T(HttpContext,"Forgot password?","שכחת סיסמה?")
        </h1>
        <p class="text-center text-ink/50 mb-12">
            @L.T(HttpContext,
                "Enter your username. Owner will reset it manually — check Notifications.",
                "הכנס שם משתמש. הבעלים יאפס אותה ידנית — ראה התראות.")
        </p>

        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-float">
            <div class="bg-paper-50 rounded-core shadow-inset p-8">
                <form method="post" class="space-y-5">
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Username","שם משתמש")</label>
                        <input asp-for="Username"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <p class="@(Model.IsSuccess ? "text-mint" : "text-rose") text-sm">@Model.Message</p>
                    }
                    <button class="w-full bg-ink text-paper-50 rounded-full px-6 py-3 mt-2 active:scale-[0.98] transition-all duration-500 ease-spring">
                        @L.T(HttpContext,"Request reset","בקש איפוס")
                    </button>
                </form>

                <p class="text-center text-xs text-ink/40 mt-6">
                    <a asp-page="/Login" class="text-accent hover:underline">@L.T(HttpContext,"Back to login","חזרה לכניסה")</a>
                </p>
            </div>
        </div>
    </div>
</section>
