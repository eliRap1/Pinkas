@page
@model BManagedWeb.Pages.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="reveal min-h-[80dvh] grid place-items-center">
    <div class="w-full max-w-md">

        <!-- Eyebrow tag -->
        <div class="flex justify-center mb-6">
            <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Workspace","סביבת עבודה")</span>
        </div>

        <h1 class="display text-5xl md:text-6xl font-bold text-center text-ink mb-2">@L.T(HttpContext,"Welcome back","ברוך שובך")</h1>
        <p class="text-center text-ink/50 mb-12">@L.T(HttpContext,"Run your business — calmly.","נהל את העסק שלך — בקלות.")</p>

        <!-- Double-bezel card -->
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-float">
            <div class="bg-paper-50 rounded-core shadow-inset p-8">
                @if (TempData["NewOwnerCode"] is string newCode && !string.IsNullOrEmpty(newCode))
                {
                    <div class="mb-5 px-4 py-3 rounded-2xl bg-mint/10 text-mint border border-mint/20 text-sm">
                        ✅ @L.T(HttpContext,"Owner account created. Your company invite code is:","חשבון בעלים נוצר. קוד הצטרפות לחברה שלך:")
                        <div class="font-mono text-lg tracking-widest mt-1">@newCode</div>
                        <div class="text-xs text-ink/60 mt-1">
                            @L.T(HttpContext,"Share this with employees who join your company. Rotate it from Settings any time.",
                                              "שתף עם עובדים שיצטרפו לחברה. ניתן להחליף מההגדרות בכל עת.")
                        </div>
                    </div>
                }
                <form id="loginForm" method="post" class="space-y-5">
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Username","שם משתמש")</label>
                        <input asp-for="Username" autocomplete="username" autofocus
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Password","סיסמה")</label>
                        <input asp-for="Password" type="password" autocomplete="current-password"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <p class="text-rose text-sm">@Model.ErrorMessage</p>
                    }

                    <button id="loginSubmit" type="submit"
                            class="group w-full inline-flex items-center justify-center gap-3 bg-ink text-paper-50 rounded-full px-6 py-3 mt-2 transition-all duration-500 ease-spring active:scale-[0.98] hover:opacity-95 disabled:opacity-70 disabled:cursor-wait">
                        <span data-label class="font-semibold">@L.T(HttpContext,"Sign in","כניסה")</span>
                        <span data-arrow class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center transition-all duration-500 ease-spring group-hover:translate-x-0.5 group-hover:-translate-y-px">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                        </span>
                        <span data-spinner class="hidden w-7 h-7 rounded-full bg-white/15 items-center justify-center">
                            <svg class="animate-spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="9" stroke-opacity="0.25"/>
                                <path d="M21 12a9 9 0 0 1-9 9" stroke-linecap="round"/>
                            </svg>
                        </span>
                    </button>
                </form>

                <script>
                    (function () {
                        var f = document.getElementById('loginForm');
                        var b = document.getElementById('loginSubmit');
                        if (!f || !b) return;
                        f.addEventListener('submit', function () {
                            // double-submit guard + spinner swap
                            if (b.disabled) return;
                            b.disabled = true;
                            var label = b.querySelector('[data-label]');
                            var arrow = b.querySelector('[data-arrow]');
                            var sp    = b.querySelector('[data-spinner]');
                            if (label) label.textContent = @Html.Raw(Json.Serialize(L.T(HttpContext, "Signing in…", "מתחבר…")));
                            if (arrow) arrow.classList.add('hidden');
                            if (sp)    { sp.classList.remove('hidden'); sp.classList.add('flex'); }
                        });
                    })();
                </script>
            </div>
        </div>

        <p class="text-xs text-ink/40 text-center mt-8">
            <a asp-page="/SignUp" class="text-accent hover:underline">@L.T(HttpContext,"Create an account","צור חשבון")</a>
            ·
            <a asp-page="/ForgotPassword" class="text-accent hover:underline">@L.T(HttpContext,"Forgot password","שכחת סיסמה")</a>
            <br/>
            @L.T(HttpContext,"Seeded admin","משתמש דמו"): <span class="font-mono">admin</span> / <span class="font-mono">admin1234</span>
        </p>
    </div>
</section>
