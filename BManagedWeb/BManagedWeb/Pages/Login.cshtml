@page
@model BManagedWeb.Pages.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="reveal min-h-[80dvh] grid place-items-center">
    <div class="w-full max-w-md">

        <!-- Eyebrow tag -->
        <div class="flex justify-center mb-6">
            <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">Workspace</span>
        </div>

        <h1 class="display text-5xl md:text-6xl font-bold text-center text-ink mb-2">Welcome back</h1>
        <p class="text-center text-ink/50 mb-12">Run your business — calmly.</p>

        <!-- Double-bezel card -->
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-float">
            <div class="bg-paper-50 rounded-core shadow-inset p-8">
                <form method="post" class="space-y-5">
                    <div>
                        <label class="pill text-ink/40 mb-2 block">Username</label>
                        <input asp-for="Username" autocomplete="username" autofocus
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">Password</label>
                        <input asp-for="Password" type="password" autocomplete="current-password"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <p class="text-rose text-sm">@Model.ErrorMessage</p>
                    }

                    <button type="submit"
                            class="group w-full inline-flex items-center justify-center gap-3 bg-ink text-paper-50 rounded-full px-6 py-3 mt-2 transition-all duration-500 ease-spring active:scale-[0.98] hover:opacity-95">
                        <span class="font-semibold">Sign in</span>
                        <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center transition-all duration-500 ease-spring group-hover:translate-x-0.5 group-hover:-translate-y-px">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                        </span>
                    </button>
                </form>
            </div>
        </div>

        <p class="text-xs text-ink/40 text-center mt-8">
            Tip — seeded admin: <span class="font-mono">admin</span> / <span class="font-mono">admin1234</span>
        </p>
    </div>
</section>
