@page
@model BManagedWeb.Pages.Owner.LoansModel
@{
    ViewData["Title"] = "Loans";
    var cur = Model.DisplayCurrency;
    string FormatPct(double v) => v <= 0 ? "—" : v.ToString("N1") + "%";
}

<div class="reveal mb-10 flex flex-wrap items-end justify-between gap-4">
    <div>
        <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Financing","מימון")</span>
        <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">@L.T(HttpContext,"Loans.","הלוואות.")</h1>
        <p class="text-ink/50 mt-3 max-w-xl">@L.T(HttpContext,
            "Track principal (קרן), interest, monthly payments, and how much your business owes vs. earns.",
            "עקוב אחר קרן ההלוואה, ריבית, תשלום חודשי, וכמה החוב שלך ביחס להכנסות העסק.")</p>
    </div>
    <form method="get" class="flex gap-3 text-sm">
        <select asp-for="DisplayCurrency" class="bg-paper-100 border border-black/5 rounded-full px-4 py-2">
            <option>ILS</option><option>USD</option>
        </select>
        <button class="bg-ink text-paper-50 rounded-full px-4 py-2">@L.T(HttpContext,"Apply","החל")</button>
    </form>
</div>

@if (TempData["LoanMsg"] is string lm)
{
    <div class="reveal mb-6 px-4 py-2 rounded-full inline-block bg-mint/10 text-mint border border-mint/20">@lm</div>
}

<!-- KPI strip -->
<section class="reveal grid md:grid-cols-4 gap-3 mb-10">
    <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-5 shadow-inset h-full">
            <div class="pill text-ink/40">@L.T(HttpContext,"Active loans","הלוואות פעילות")</div>
            <div class="display text-3xl font-bold mt-2">@Model.Summary.LoanCount</div>
            @if (Model.Summary.KerenBackedCount > 0)
            {
                <div class="text-xs text-mint mt-1">@Model.Summary.KerenBackedCount @L.T(HttpContext,"state-backed (קרן)","בערבות מדינה")</div>
            }
        </div>
    </div>
    <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-5 shadow-inset h-full">
            <div class="pill text-ink/40">@L.T(HttpContext,"Outstanding (קרן נותרת)","יתרת קרן")</div>
            <div class="display text-3xl font-bold mt-2">@Model.Summary.TotalRemaining.ToString("N0") <span class="text-base text-ink/40">@cur</span></div>
            <div class="text-xs text-ink/40 mt-1">
                @L.T(HttpContext,"of original","מתוך מקורי") @Model.Summary.TotalPrincipal.ToString("N0") @cur
            </div>
        </div>
    </div>
    <div class="bg-amber/15 ring-1 ring-amber/30 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-5 shadow-inset h-full">
            <div class="pill text-ink/40">@L.T(HttpContext,"Monthly payment","תשלום חודשי")</div>
            <div class="display text-3xl font-bold mt-2 text-amber">@Model.Summary.MonthlyPaymentTotal.ToString("N0") <span class="text-base text-ink/40">@cur</span></div>
            @if (Model.Summary.NextPaymentDate.HasValue)
            {
                <div class="text-xs text-ink/50 mt-1">
                    @L.T(HttpContext,"Next","הבא"): @Model.Summary.NextPaymentDate.Value.ToString("dd/MM/yyyy")
                </div>
            }
        </div>
    </div>
    <div class="bg-ink rounded-shell p-1.5 text-paper-50">
        <div class="bg-ink-soft rounded-core p-5 shadow-inset h-full">
            <div class="pill text-paper-50/50">@L.T(HttpContext,"Debt vs annual income","חוב ביחס להכנסה שנתית")</div>
            <div class="display text-3xl font-bold mt-2">@FormatPct(Model.Summary.DebtToAnnualIncomePct)</div>
            <div class="text-xs text-paper-50/50 mt-1">
                @L.T(HttpContext,"Monthly burden","נטל חודשי"): @FormatPct(Model.Summary.MonthlyDebtServiceRatioPct)
            </div>
        </div>
    </div>
</section>

@if (Model.Summary.MonthlyDebtServiceRatioPct >= 40)
{
    <div class="reveal mb-6 px-5 py-4 rounded-2xl bg-rose/10 text-ink border border-rose/30 max-w-3xl">
        ⚠️ @L.T(HttpContext,
            "Your monthly loan payments exceed 40% of recent monthly income. This is a high debt-service ratio.",
            "התשלום החודשי על ההלוואות מעל 40% מההכנסה החודשית הממוצעת. נטל חוב גבוה.")
    </div>
}
else if (Model.Summary.MonthlyDebtServiceRatioPct >= 25)
{
    <div class="reveal mb-6 px-5 py-4 rounded-2xl bg-amber/10 text-ink border border-amber/30 max-w-3xl">
        @L.T(HttpContext,
            "Monthly loan payments are 25–40% of recent monthly income. Watch this ratio as revenue fluctuates.",
            "התשלום החודשי על ההלוואות 25–40% מההכנסה. כדאי לעקוב אם ההכנסה משתנה.")
    </div>
}

<!-- Add loan form -->
<form method="post" asp-page-handler="Add" class="reveal mb-10 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 max-w-4xl">
    <div class="bg-paper-50 rounded-core p-6 shadow-inset">
        <div class="flex items-center justify-between mb-4">
            <h2 class="display text-2xl font-semibold">@L.T(HttpContext,"Add a new loan","הוסף הלוואה חדשה")</h2>
            <span class="pill text-ink/40">@L.T(HttpContext,"All fields, please","אנא מלא את כל השדות")</span>
        </div>

        <div class="grid md:grid-cols-3 gap-3">
            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Lender (bank / fund)","המלווה (בנק / קרן)")</label>
                <input asp-for="NewLender" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="@L.T(HttpContext,"e.g. Bank Hapoalim, Keren Shemesh","למשל בנק הפועלים, קרן שמש")"/>
            </div>
            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Principal (קרן)","קרן ההלוואה")</label>
                <input asp-for="NewPrincipal" type="number" step="0.01" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="@L.T(HttpContext,"Original borrowed amount","סכום מקורי שלוויתי")"/>
            </div>
            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Interest rate %","ריבית שנתית %")</label>
                <input asp-for="NewInterestRate" type="number" step="0.01" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="6.5"/>
            </div>

            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Monthly payment","תשלום חודשי")</label>
                <input asp-for="NewMonthlyPayment" type="number" step="0.01" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="@L.T(HttpContext,"What you pay every month","הסכום שאתה משלם כל חודש")"/>
            </div>
            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Term (months)","משך (בחודשים)")</label>
                <input asp-for="NewTermMonths" type="number" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="60"/>
            </div>
            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Start date","תאריך התחלה")</label>
                <input asp-for="NewStartDate" type="date" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"/>
            </div>

            <div>
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Currency","מטבע")</label>
                <select asp-for="NewCurrency" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5">
                    <option>ILS</option><option>USD</option>
                </select>
            </div>
            <div class="md:col-span-2">
                <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Purpose","מטרת ההלוואה")</label>
                <input asp-for="NewPurpose" class="w-full bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5"
                       placeholder="@L.T(HttpContext,"e.g. equipment, working capital","למשל ציוד, הון חוזר")"/>
            </div>

            <label class="md:col-span-3 flex items-start gap-3 bg-mint/10 border border-mint/30 rounded-2xl px-4 py-3 cursor-pointer">
                <input asp-for="NewIsKerenBacked" type="checkbox" class="mt-1 accent-mint"/>
                <span>
                    <span class="block font-semibold text-ink">@L.T(HttpContext,"State-backed business fund (קרן הלוואות בערבות מדינה)","הלוואה מקרן בערבות מדינה")</span>
                    <span class="block text-xs text-ink/60 mt-0.5">@L.T(HttpContext,
                        "Loans from Keren Shemesh, Keren Koret, the SME state-guaranteed fund, etc. usually carry lower rates.",
                        "הלוואות מקרן שמש, קרן קורת, קרן הלוואות בערבות מדינה לעסקים קטנים — בדרך כלל בריבית נמוכה.")</span>
                </span>
            </label>

            <button class="md:col-span-3 bg-mint text-white rounded-full px-6 py-3 mt-1 active:scale-[0.98]">
                + @L.T(HttpContext,"Save loan","שמור הלוואה")
            </button>
        </div>
    </div>
</form>

<!-- Loans list -->
<section class="reveal grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
    @foreach (var l in Model.Loans)
    {
        var pct = l.Principal <= 0 ? 0
            : Math.Max(0, Math.Min(100, (int)Math.Round((double)((l.Principal - l.RemainingBalance) / l.Principal) * 100)));
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                <div class="flex items-start justify-between gap-3 mb-2">
                    <div>
                        <span class="pill text-ink/40">@l.Currency · @l.InterestRatePct.ToString("N2")%</span>
                        <h3 class="display text-2xl font-semibold mt-1">@l.Lender</h3>
                        <p class="text-sm text-ink/50">@(string.IsNullOrEmpty(l.Purpose) ? "—" : l.Purpose)</p>
                    </div>
                    <div class="text-right">
                        @if (l.IsKerenBacked)
                        { <span class="pill bg-mint/15 text-mint border border-mint/30 rounded-full px-2 py-0.5 text-xs">קרן ⓘ</span> }
                        @if (!l.IsActive)
                        { <span class="pill bg-black/5 text-ink/50 border border-black/10 rounded-full px-2 py-0.5 text-xs ml-1">@L.T(HttpContext,"Closed","נסגרה")</span> }
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-2 mt-4 text-sm">
                    <div class="bg-paper-100 rounded-2xl px-3 py-2">
                        <div class="pill text-ink/40">@L.T(HttpContext,"Principal","קרן")</div>
                        <div class="display font-semibold">@l.Principal.ToString("N0")</div>
                    </div>
                    <div class="bg-paper-100 rounded-2xl px-3 py-2">
                        <div class="pill text-ink/40">@L.T(HttpContext,"Remaining","יתרה")</div>
                        <div class="display font-semibold">@l.RemainingBalance.ToString("N0")</div>
                    </div>
                    <div class="bg-paper-100 rounded-2xl px-3 py-2">
                        <div class="pill text-ink/40">@L.T(HttpContext,"Monthly","חודשי")</div>
                        <div class="display font-semibold">@l.MonthlyPayment.ToString("N0")</div>
                    </div>
                </div>

                <!-- Progress bar -->
                <div class="mt-4 h-2 rounded-full bg-paper-100 overflow-hidden">
                    <div class="h-full bg-mint rounded-full" style="width:@(pct)%"></div>
                </div>
                <div class="text-xs text-ink/50 mt-1 flex items-center justify-between">
                    <span>@pct% @L.T(HttpContext,"paid down","נפרע")</span>
                    @if (l.NextPaymentDate.HasValue)
                    { <span>@L.T(HttpContext,"Next","הבא"): @l.NextPaymentDate.Value.ToString("dd/MM/yyyy")</span> }
                </div>

                @{
                    // Build a sparkline of the running RemainingBalance from
                    // oldest payment to newest. Polyline goes from full
                    // principal (left) down to current remaining (right).
                    var hist2 = Model.PaymentHistory.GetValueOrDefault(l.Id);
                    if (hist2 != null && hist2.Count >= 2)
                    {
                        var asc = hist2.OrderBy(p => p.PaidDate).ToList();
                        decimal running = l.Principal;
                        var balances = new List<decimal> { l.Principal };
                        foreach (var p in asc)
                        {
                            running -= p.PrincipalPortion;
                            if (running < 0) running = 0;
                            balances.Add(running);
                        }
                        decimal max = balances.Max();
                        if (max <= 0) max = 1;
                        int W = 240, H = 36;
                        var pts = string.Join(" ",
                            balances.Select((b, i) =>
                                $"{(int)(i * W / (double)(balances.Count - 1))},{(int)(H - (double)(b / max) * H)}"));
                        <svg viewBox="0 0 @W @H" class="mt-3 w-full h-9" preserveAspectRatio="none">
                            <polyline fill="none" stroke="#10B981" stroke-width="2" points="@pts"></polyline>
                        </svg>
                        <div class="text-[10px] text-ink/40 -mt-1">
                            @L.T(HttpContext,"Balance trend","מגמת יתרה")
                        </div>
                    }
                }

                <details class="mt-4">
                    <summary class="cursor-pointer pill text-ink/50">@L.T(HttpContext,"Record a payment / history","רשום תשלום / היסטוריה")</summary>
                    <form method="post" asp-page-handler="Pay" class="mt-3 grid grid-cols-3 gap-2 text-sm">
                        <input type="hidden" name="LoanId" value="@l.Id"/>
                        <div>
                            <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Date","תאריך")</label>
                            <input name="PaidDate" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="w-full bg-white border border-black/5 rounded-xl px-3 py-2 text-sm"/>
                        </div>
                        <div>
                            <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Amount","סכום")</label>
                            <input name="Amount" type="number" step="0.01" value="@l.MonthlyPayment.ToString("F2")" class="w-full bg-white border border-black/5 rounded-xl px-3 py-2 text-sm"/>
                        </div>
                        <div>
                            <label class="pill text-ink/40 mb-1 block">@L.T(HttpContext,"Of which principal","מתוכו קרן")</label>
                            <input name="PrincipalPortion" type="number" step="0.01" value="@(((l.MonthlyPayment * 0.7m)).ToString("F2"))" class="w-full bg-white border border-black/5 rounded-xl px-3 py-2 text-sm"/>
                        </div>
                        <button class="col-span-3 bg-ink text-paper-50 rounded-full px-4 py-2 text-sm">+ @L.T(HttpContext,"Record payment","רשום תשלום")</button>
                    </form>

                    @{ var hist = Model.PaymentHistory.GetValueOrDefault(l.Id); }
                    @if (hist != null && hist.Count > 0)
                    {
                        <div class="mt-3 text-xs text-ink/50 space-y-1">
                            @foreach (var p in hist.Take(6))
                            {
                                <div class="flex justify-between bg-paper-100 rounded-xl px-3 py-1.5">
                                    <span>@p.PaidDate.ToString("dd/MM/yyyy")</span>
                                    <span>@p.Amount.ToString("N0") (@L.T(HttpContext,"P","ק"): @p.PrincipalPortion.ToString("N0"))</span>
                                </div>
                            }
                        </div>
                    }
                </details>

                <form method="post" asp-page-handler="Delete" class="mt-3" onsubmit="return confirm('Delete this loan? Payment history will also be removed.');">
                    <input type="hidden" name="id" value="@l.Id"/>
                    <button class="text-xs text-rose hover:underline">🗑 @L.T(HttpContext,"Delete loan","מחק הלוואה")</button>
                </form>
            </div>
        </div>
    }
    @if (Model.Loans.Count == 0)
    {
        <div class="md:col-span-2 text-center py-20 text-ink/40">
            @L.T(HttpContext,"No loans logged yet — add your first above.","אין הלוואות עדיין — הוסף ראשונה למעלה.")
        </div>
    }
</section>
