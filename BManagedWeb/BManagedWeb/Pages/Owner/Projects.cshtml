@page
@model BManagedWeb.Pages.Owner.ProjectsModel
@{ ViewData["Title"] = "Projects"; }

<div class="reveal mb-12 flex flex-wrap items-end justify-between gap-4">
    <div>
        <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">Pipeline</span>
        <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">Projects.</h1>
    </div>
    <form method="get" class="flex items-center gap-3 text-sm">
        <select asp-for="StatusFilter" class="bg-paper-100 border border-black/5 rounded-full px-4 py-2">
            <option value="">All</option>
            <option value="Active">Active</option>
            <option value="AwaitingPayment">Awaiting Payment</option>
            <option value="Done">Done</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <button class="bg-ink text-paper-50 rounded-full px-4 py-2">Filter</button>
    </form>
</div>

<form method="post" asp-page-handler="Add" class="reveal mb-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 max-w-3xl">
    <div class="bg-paper-50 rounded-core p-6 shadow-inset grid md:grid-cols-3 gap-3">
        <select asp-for="NewCustomerId" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5">
            <option value="0">Customer…</option>
            @foreach (var c in Model.Customers)
            { <option value="@c.Id">@c.BusinessName</option> }
        </select>
        <input asp-for="NewTitle" placeholder="Project title" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
        <input asp-for="NewBudget" type="number" step="0.01" placeholder="Budget" class="bg-paper-100 border border-black/5 rounded-2xl px-4 py-2.5" />
        <button class="md:col-span-3 bg-mint text-white rounded-full px-6 py-3 mt-1 active:scale-[0.98]">Add project</button>
    </div>
</form>

<section class="reveal grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var p in Model.Projects)
    {
        var color = p.Status switch { "Done" => "mint", "AwaitingPayment" => "amber", "Cancelled" => "rose", _ => "accent" };
        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 hover:shadow-float transition-all duration-500 ease-spring">
            <div class="bg-paper-50 rounded-core p-6 shadow-inset h-full">
                <span class="pill text-ink/40">#@p.Id · @p.Currency</span>
                <div class="display text-2xl font-semibold mt-2">@p.Title</div>
                <div class="text-xs text-ink/40 mt-1">Due @(p.DueDate?.ToString("dd MMM yyyy") ?? "—")</div>
                <div class="display text-xl font-semibold mt-3">@p.TotalBudget.ToString("N0") <span class="text-ink/40 text-xs">@p.Currency</span></div>
                <div class="pill rounded-full px-2 py-0.5 mt-4 inline-block bg-@(color)/10 text-@(color) border border-@(color)/20">@p.Status</div>
            </div>
        </div>
    }
    @if (Model.Projects.Count == 0)
    { <div class="md:col-span-3 text-center py-20 text-ink/40">No projects yet.</div> }
</section>
