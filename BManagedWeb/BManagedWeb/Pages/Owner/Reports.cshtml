@page
@model BManagedWeb.Pages.Owner.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<div class="reveal mb-12 flex items-end justify-between flex-wrap gap-4">
    <div>
        <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"Reports","דוחות")</span>
        <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">@L.T(HttpContext,"Numbers, on tap.","המספרים, בלחיצה.")</h1>
    </div>
    <form method="get" class="flex items-center gap-3 text-sm">
        <select asp-for="Year" asp-items="Model.YearOptions" class="bg-paper-100 border border-black/5 rounded-full px-4 py-2"></select>
        <select asp-for="Month" asp-items="Model.MonthOptions" class="bg-paper-100 border border-black/5 rounded-full px-4 py-2"></select>
        <select asp-for="DisplayCurrency" class="bg-paper-100 border border-black/5 rounded-full px-4 py-2">
            <option>ILS</option><option>USD</option>
        </select>
        <button class="bg-ink text-paper-50 rounded-full px-4 py-2">@L.T(HttpContext,"Apply","החל")</button>
        <a asp-page-handler="Csv" asp-route-displayCurrency="@Model.DisplayCurrency"
           asp-route-Year="@Model.Year" asp-route-Month="@Model.Month"
           class="bg-mint text-white rounded-full px-4 py-2">@L.T(HttpContext,"Export CSV","ייצוא CSV")</a>
    </form>
</div>

@if (TempData["VatMsg"] is string vatMsg)
{
    <div class="reveal mb-6 px-4 py-2 rounded-full inline-block bg-mint/10 text-mint border border-mint/20">@vatMsg</div>
}

@if (Model.PaturOverThreshold)
{
    <div class="reveal mb-6 px-5 py-4 rounded-2xl bg-amber/15 text-ink border border-amber/30 max-w-3xl">
        ⚠️ @L.T(HttpContext,
            $"Osek Patur revenue this year is {Model.YearPl.Income:N0} ₪ — over the {Model.PaturThreshold:N0} ₪ threshold. You must register as Osek Murshe with the VAT authority.",
            $"מחזור עוסק פטור מתחילת השנה: {Model.YearPl.Income:N0} ₪ — מעל סף {Model.PaturThreshold:N0} ₪. חובה לעבור לעוסק מורשה ברשות המסים.")
    </div>
}

@if (!string.IsNullOrEmpty(Model.ZairNote))
{
    <div class="reveal mb-6 px-5 py-4 rounded-2xl bg-mint/10 text-ink border border-mint/30 max-w-3xl">
        ✅ @Model.ZairNote
    </div>
}

@{
    var canZair = Model.BusinessType == "Patur" || Model.BusinessType == "Murshe";
}
@if (canZair)
{
    <form method="post" asp-page-handler="ToggleZair" class="reveal mb-8 max-w-3xl bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-5 shadow-inset flex items-center gap-4">
            <input type="hidden" name="Year"  value="@Model.Year"/>
            <input type="hidden" name="Month" value="@Model.Month"/>
            <input type="hidden" name="DisplayCurrency" value="@Model.DisplayCurrency"/>
            <div class="flex-1">
                <div class="pill text-ink/40">@L.T(HttpContext,"Osek Zair status","סטטוס עוסק זעיר")</div>
                <div class="text-sm mt-1">
                    @L.T(HttpContext,"Income tax computed on 70% of revenue (flat 30% deemed-expenses). Available while annual revenue ≤ ~122,833 ₪.",
                                      "מס הכנסה מחושב על 70% מהמחזור (ניכוי הוצאות אוטומטי 30%). זמין כל עוד מחזור שנתי עד ~122,833 ₪.")
                </div>
            </div>
            @if (Model.IsZair)
            {
                <button name="wantZair" value="false" class="bg-rose/10 text-rose border border-rose/30 rounded-full px-4 py-2 text-sm">
                    @L.T(HttpContext,"Disable Zair","בטל זעיר")
                </button>
            }
            else
            {
                <button name="wantZair" value="true" class="bg-mint text-white rounded-full px-4 py-2 text-sm">
                    @L.T(HttpContext,"Enable Zair","הפעל זעיר")
                </button>
            }
        </div>
    </form>
}

<!-- VAT explainer -->
<details class="reveal max-w-3xl mb-8 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
    <summary class="bg-paper-50 rounded-core p-5 shadow-inset cursor-pointer text-sm">
        <span class="pill text-ink/40">@L.T(HttpContext,"How does the Owner pay VAT?","איך הבעלים משלם מע״מ?")</span>
        <span class="text-ink/70 ml-2">@L.T(HttpContext,"Click to learn more about VAT collected, paid, and due.",
                                              "לחץ להסבר על מע״מ עסקאות, תשומות וההפרש לתשלום.")</span>
    </summary>
    <div class="bg-paper-50 rounded-core px-5 pb-5 -mt-1 text-sm text-ink/70 space-y-2">
        <p>
            <span class="font-semibold">@L.T(HttpContext,"VAT collected","מע״מ עסקאות")</span> —
            @L.T(HttpContext,"the 18 % VAT charged on top of every invoice you issue.",
                              "18% המע״מ שגביית מהלקוחות בכל חשבונית.")
        </p>
        <p>
            <span class="font-semibold">@L.T(HttpContext,"VAT paid","מע״מ תשומות")</span> —
            @L.T(HttpContext,"the VAT portion of expenses you logged. Deductible against VAT collected.",
                              "מרכיב המע״מ בהוצאות שדיווחת. ניתן לקיזוז מול מע״מ עסקאות.")
        </p>
        <p>
            <span class="font-semibold">@L.T(HttpContext,"VAT due","מע״מ לתשלום")</span> =
            <span class="font-mono">collected − paid</span>.
            @L.T(HttpContext,"Owner files Form 836/874 with the Israel Tax Authority and transfers this amount via bank.",
                              "הבעלים מגיש טופס 836/874 לרשות המסים ומעביר את הסכום בהעברה בנקאית.")
        </p>
        <p class="text-ink/50">
            @L.T(HttpContext,"Click 'Mark as paid' on the VAT-due card after you have paid. The system records a matching expense entry against the Tax Authority so the next month starts clean.",
                              "לחץ ‘סמן ששולם’ אחרי התשלום בפועל. המערכת תרשום הוצאה תואמת מול רשות המסים כדי שהחודש הבא יתחיל נקי.")
        </p>
    </div>
</details>

<section class="grid md:grid-cols-12 gap-4 md:gap-6 mb-12">
    <div class="reveal md:col-span-4 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset h-full">
            <span class="pill text-ink/40">@L.T(HttpContext,"VAT collected","מע״מ עסקאות")</span>
            <div class="display text-5xl font-bold mt-3">@Model.Vat.VatCollected.ToString("N0") <span class="text-base text-ink/40">@Model.DisplayCurrency</span></div>
        </div>
    </div>
    <div class="reveal md:col-span-4 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset h-full">
            <span class="pill text-ink/40">@L.T(HttpContext,"VAT paid","מע״מ תשומות")</span>
            <div class="display text-5xl font-bold mt-3">@Model.Vat.VatPaid.ToString("N0") <span class="text-base text-ink/40">@Model.DisplayCurrency</span></div>
        </div>
    </div>
    <div class="reveal md:col-span-4 bg-ink rounded-shell p-1.5">
        <div class="bg-ink-soft rounded-core p-8 text-paper-50 shadow-inset h-full flex flex-col">
            <span class="pill text-paper-50/50">@L.T(HttpContext,"VAT due","מע״מ לתשלום")</span>
            <div class="display text-5xl font-bold mt-3">@Model.Vat.VatDue.ToString("N0") <span class="text-base text-paper-50/50">@Model.DisplayCurrency</span></div>
            @if (Model.ShowMarkVatPaid)
            {
                <form method="post" asp-page-handler="PayVat" class="mt-auto pt-4">
                    <input type="hidden" name="Year"  value="@Model.Year"/>
                    <input type="hidden" name="Month" value="@Model.Month"/>
                    <input type="hidden" name="DisplayCurrency" value="@Model.DisplayCurrency"/>
                    <button class="bg-mint text-white rounded-full px-4 py-2 text-sm w-full">
                        @L.T(HttpContext,"Mark as paid to Tax Authority","סמן ששולם לרשות המסים")
                    </button>
                </form>
            }
            else
            {
                <div class="mt-auto pt-4 text-xs text-paper-50/50">
                    @L.T(HttpContext,"Mark-as-paid applies to Osek Murshe only.","סימון תשלום מע״מ רלוונטי לעוסק מורשה בלבד.")
                </div>
            }
        </div>
    </div>

    <div class="reveal md:col-span-7 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset h-full">
            <h2 class="display text-2xl font-semibold mb-4">@L.T(HttpContext,"Income vs expenses","הכנסות מול הוצאות")</h2>
            <canvas id="incomeExpenseChart" height="120"></canvas>
        </div>
    </div>

    <div class="reveal md:col-span-5 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset h-full">
            <h2 class="display text-2xl font-semibold mb-4">@L.T(HttpContext,"Expenses by category","הוצאות לפי קטגוריה")</h2>
            <canvas id="expenseChart" height="120"></canvas>
        </div>
    </div>

    <!-- P&L card -->
    <div class="reveal md:col-span-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset">
            <div class="flex flex-wrap justify-between items-end mb-6 gap-4">
                <div>
                    <span class="pill text-ink/40">@L.T(HttpContext,"Profit & Loss","רווח והפסד")</span>
                    <h2 class="display text-2xl font-semibold">@L.T(HttpContext,"Money in, money out, what's left.","הכנסות, הוצאות, מה נשאר.")</h2>
                </div>
                <div class="text-xs text-ink/40">@L.T(HttpContext,"Period","תקופה"): @Model.Year-@Model.Month.ToString("D2") · @Model.DisplayCurrency</div>
            </div>

            <!-- Month -->
            <div class="grid md:grid-cols-3 gap-3 mb-6">
                <div class="bg-paper-100 rounded-2xl px-5 py-4">
                    <div class="pill text-ink/40">@L.T(HttpContext,"Income (this month)","הכנסות (החודש)")</div>
                    <div class="display text-2xl font-semibold mt-1 text-mint">@Model.MonthPl.Income.ToString("N0") <span class="text-ink/40 text-xs">@Model.DisplayCurrency</span></div>
                </div>
                <div class="bg-paper-100 rounded-2xl px-5 py-4">
                    <div class="pill text-ink/40">@L.T(HttpContext,"Expenses (this month)","הוצאות (החודש)")</div>
                    <div class="display text-2xl font-semibold mt-1 text-rose">@Model.MonthPl.Expenses.ToString("N0") <span class="text-ink/40 text-xs">@Model.DisplayCurrency</span></div>
                </div>
                <div class="bg-paper-100 rounded-2xl px-5 py-4">
                    <div class="pill text-ink/40">@L.T(HttpContext,"Gross profit (this month)","רווח ברוטו (החודש)")</div>
                    <div class="display text-2xl font-semibold mt-1">@Model.MonthPl.Profit.ToString("N0") <span class="text-ink/40 text-xs">@Model.DisplayCurrency</span></div>
                </div>
            </div>

            <!-- Year-to-year + tax brackets -->
            <div class="grid md:grid-cols-4 gap-3">
                <div class="bg-ink rounded-2xl px-5 py-4 text-paper-50">
                    <div class="pill text-paper-50/50">@L.T(HttpContext,"Income (year)","הכנסות (שנתי)")</div>
                    <div class="display text-2xl font-semibold mt-1">@Model.YearPl.Income.ToString("N0") <span class="text-paper-50/40 text-xs">@Model.DisplayCurrency</span></div>
                </div>
                <div class="bg-ink rounded-2xl px-5 py-4 text-paper-50">
                    <div class="pill text-paper-50/50">@L.T(HttpContext,"Expenses (year)","הוצאות (שנתי)")</div>
                    <div class="display text-2xl font-semibold mt-1">@Model.YearPl.Expenses.ToString("N0") <span class="text-paper-50/40 text-xs">@Model.DisplayCurrency</span></div>
                </div>
                <div class="bg-amber/20 rounded-2xl px-5 py-4 border border-amber/30">
                    <div class="pill text-ink/50">@L.T(HttpContext,"Income tax (brackets)","מס הכנסה (מדרגות)")</div>
                    <div class="display text-2xl font-semibold mt-1 text-amber">−@Model.YearTax.ToString("N0") <span class="text-ink/40 text-xs">@Model.DisplayCurrency</span></div>
                    <div class="text-xs text-ink/50 mt-1">
                        @L.T(HttpContext,"Taxable base","בסיס מס"): @Model.TaxableProfit.ToString("N0") @Model.DisplayCurrency
                    </div>
                </div>
                <div class="bg-mint/15 rounded-2xl px-5 py-4 border border-mint/30">
                    <div class="pill text-ink/50">@L.T(HttpContext,"Net profit (year)","רווח נטו (שנתי)")</div>
                    <div class="display text-2xl font-semibold mt-1 text-mint">@Model.YearNet.ToString("N0") <span class="text-ink/40 text-xs">@Model.DisplayCurrency</span></div>
                    <div class="text-xs text-ink/50 mt-1">= @L.T(HttpContext,"Gross","ברוטו") − @L.T(HttpContext,"Tax","מס")</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.TaxNote))
            {
                <div class="mt-4 text-xs text-ink/60 bg-paper-100 rounded-2xl px-4 py-3 border border-black/5">
                    📌 @Model.TaxNote
                </div>
            }

            <!-- Bracket table -->
            <details class="mt-6 text-xs text-ink/60">
                <summary class="cursor-pointer pill text-ink/40">@L.T(HttpContext,"Show 2026 income-tax brackets","הצג מדרגות מס 2026")</summary>
                <table class="mt-3 w-full text-left">
                    <thead><tr class="text-ink/40">
                        <th class="py-1">@L.T(HttpContext,"From","מ-")</th>
                        <th class="py-1">@L.T(HttpContext,"To","עד")</th>
                        <th class="py-1">@L.T(HttpContext,"Rate","שיעור")</th>
                    </tr></thead>
                    <tbody>
                        <tr><td>0</td><td>84,120</td><td>10%</td></tr>
                        <tr><td>84,120</td><td>120,720</td><td>14%</td></tr>
                        <tr><td>120,720</td><td>193,800</td><td>20%</td></tr>
                        <tr><td>193,800</td><td>269,280</td><td>31%</td></tr>
                        <tr><td>269,280</td><td>560,280</td><td>35%</td></tr>
                        <tr><td>560,280</td><td>721,560</td><td>47%</td></tr>
                        <tr><td>721,560</td><td>—</td><td>50%</td></tr>
                    </tbody>
                </table>
                <p class="mt-2 text-ink/50">@L.T(HttpContext,"Approximate 2026 brackets for individuals (NIS). Real liability depends on credit points, deductions, and other adjustments — consult an accountant.",
                                                 "מדרגות משוערות 2026 ליחיד (₪). חבות מס ממשית תלויה בנקודות זיכוי, ניכויים ועוד — היוועצו עם רו״ח.")</p>
            </details>
        </div>
    </div>

    <div class="reveal md:col-span-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset">
            <h2 class="display text-2xl font-semibold mb-6">@L.T(HttpContext,"Customers — invoiced vs paid","לקוחות — חויב מול שולם")</h2>
            <div class="grid md:grid-cols-2 gap-3">
                @foreach (var r in Model.TopCustomers)
                {
                    <div class="flex items-center justify-between bg-paper-100 rounded-2xl px-5 py-4 border border-black/5">
                        <div class="font-medium">@r.BusinessName</div>
                        <div class="display font-semibold">@r.TotalInvoiced.ToString("N0") <span class="text-ink/40 text-xs">@r.DisplayCurrency</span></div>
                    </div>
                }
                @if (Model.TopCustomers.Count == 0)
                {
                    <div class="text-ink/40 md:col-span-2 py-8 text-center">No revenue yet — issue an invoice to populate.</div>
                }
            </div>
        </div>
    </div>

    <div class="reveal md:col-span-12 bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
        <div class="bg-paper-50 rounded-core p-8 shadow-inset">
            <h2 class="display text-2xl font-semibold mb-6">@L.T(HttpContext,"Expense breakdown","פירוט הוצאות")</h2>
            <div class="grid md:grid-cols-3 gap-3">
                @foreach (var b in Model.ExpenseBreakdown)
                {
                    <div class="bg-paper-100 rounded-2xl px-5 py-4 border border-black/5">
                        <div class="pill text-ink/40">@b.CategoryName @(b.IsVatDeductible ? "· VAT-deductible" : "")</div>
                        <div class="display font-semibold mt-1">@b.Total.ToString("N0") <span class="text-ink/40 text-xs">@b.DisplayCurrency</span></div>
                    </div>
                }
                @if (Model.ExpenseBreakdown.Count == 0)
                {
                    <div class="text-ink/40 md:col-span-3 py-8 text-center">No expenses logged for this period.</div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  new Chart(document.getElementById('incomeExpenseChart'), {
    type: 'bar',
    data: {
      labels: ['Income','Expenses','VAT due'],
      datasets: [{
        label: '@Model.DisplayCurrency',
        data: [@Model.Vat.IncomeTotal.ToString("F2"), @Model.Vat.ExpensesTotal.ToString("F2"), @Model.Vat.VatDue.ToString("F2")],
        backgroundColor: ['#10B981','#EF4444','#F59E0B'],
        borderRadius: 12,
      }]
    },
    options: { plugins:{ legend:{ display:false } }, scales:{ y:{ beginAtZero:true } } }
  });
  @{
      var labels = string.Join(",", Model.ExpenseBreakdown.Select(r => "'" + (r.CategoryName ?? "").Replace("'", " ") + "'"));
      var values = string.Join(",", Model.ExpenseBreakdown.Select(r => r.Total.ToString("F2")));
  }
  new Chart(document.getElementById('expenseChart'), {
    type: 'doughnut',
    data: {
      labels: [@Html.Raw(labels)],
      datasets: [{
        data: [@values],
        backgroundColor: ['#3B5BFF','#10B981','#F59E0B','#EF4444','#8B5CF6','#06B6D4','#84CC16','#EC4899']
      }]
    },
    options: { plugins:{ legend:{ position:'bottom' } } }
  });
</script>
}
