@page
@model BManagedWeb.Pages.Owner.UsersModel
@{ ViewData["Title"] = "Users"; }

<div class="reveal mb-12">
    <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">Admin</span>
    <h1 class="display text-5xl md:text-7xl font-bold mt-4 leading-[0.95]">Users.</h1>
    <p class="text-ink/50 mt-3">Approve, promote, deactivate.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="reveal mb-6 px-4 py-2 rounded-full inline-block @(Model.IsSuccess ? "bg-mint/10 text-mint border border-mint/20" : "bg-rose/10 text-rose border border-rose/20")">@Model.Message</div>
}

<!-- Pending approvals -->
@if (Model.Pending.Count > 0)
{
    <section class="reveal bg-amber/[0.06] ring-1 ring-amber/20 rounded-shell p-1.5 mb-6">
        <div class="bg-paper-50 rounded-core p-6 shadow-inset">
            <h2 class="display text-2xl font-semibold mb-4 text-amber">Pending approvals (@Model.Pending.Count)</h2>
            <div class="grid md:grid-cols-2 gap-3">
                @foreach (var u in Model.Pending)
                {
                    <div class="flex items-center justify-between bg-paper-100 rounded-2xl px-5 py-4 border border-black/5">
                        <div>
                            <div class="font-medium">@u.Username</div>
                            <div class="text-xs text-ink/50">@u.Email · @u.Phone</div>
                            <div class="pill rounded-full px-2 py-0.5 mt-1 inline-block bg-black/5 text-ink/60">@u.Role</div>
                        </div>
                        <div class="flex gap-2">
                            <form method="post" asp-page-handler="Approve" asp-route-id="@u.Id">
                                <button class="bg-mint text-white rounded-full px-4 py-2 text-sm">Approve</button>
                            </form>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@u.Id">
                                <button class="bg-rose text-white rounded-full px-4 py-2 text-sm">Reject</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- All users -->
<section class="reveal bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5">
    <div class="bg-paper-50 rounded-core p-6 shadow-inset">
        <h2 class="display text-2xl font-semibold mb-4">All users (@Model.AllUsers.Count)</h2>
        <table class="w-full text-sm">
            <thead><tr class="text-ink/40 pill">
                <th class="text-left py-2">Username</th>
                <th class="text-left">Email</th>
                <th class="text-left">Role</th>
                <th class="text-left">Status</th>
                <th class="text-right">Actions</th>
            </tr></thead>
            <tbody>
            @foreach (var u in Model.AllUsers)
            {
                var color = u.Role == "Owner" ? "accent" : u.Role == "Employee" ? "amber" : "mint";
                <tr class="border-t border-black/5">
                    <td class="py-2 font-medium">@u.Username</td>
                    <td class="text-ink/60">@u.Email</td>
                    <td><span class="pill rounded-full px-2 py-0.5 bg-@(color)/10 text-@(color) border border-@(color)/20">@u.Role</span></td>
                    <td>
                        @if (u.IsActive)
                        { <span class="pill text-mint">Active</span> }
                        else
                        { <span class="pill text-rose">Blocked</span> }
                    </td>
                    <td class="text-right">
                        <form method="post" asp-page-handler="Promote" asp-route-id="@u.Id" class="inline">
                            <select name="newRole" class="text-xs bg-paper-100 border border-black/5 rounded-full px-2 py-1">
                                <option value="Owner"    selected="@(u.Role=="Owner")">Owner</option>
                                <option value="Employee" selected="@(u.Role=="Employee")">Employee</option>
                                <option value="Client"   selected="@(u.Role=="Client")">Client</option>
                            </select>
                            <button class="bg-ink text-paper-50 rounded-full px-3 py-1 text-xs ml-1">Set</button>
                        </form>
                        <form method="post" asp-page-handler="Toggle" asp-route-id="@u.Id" class="inline">
                            <button class="bg-amber text-white rounded-full px-3 py-1 text-xs">@(u.IsActive ? "Block" : "Unblock")</button>
                        </form>
                        <form method="post" asp-page-handler="Reset" asp-route-id="@u.Id" class="inline">
                            <button class="bg-paper-200 text-ink rounded-full px-3 py-1 text-xs" title="Reset to 'reset1234'">Reset PW</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
