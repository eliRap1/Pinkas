@page
@model BManagedWeb.Pages.SignUpModel
@{ ViewData["Title"] = "Create account"; }

<section class="reveal min-h-[80dvh] grid place-items-center">
    <div class="w-full max-w-md">
        <div class="flex justify-center mb-6">
            <span class="pill rounded-full px-3 py-1 bg-black/5 border border-black/5">@L.T(HttpContext,"New here","חדש כאן")</span>
        </div>
        <h1 class="display text-5xl md:text-6xl font-bold text-center text-ink mb-2">@L.T(HttpContext,"Create account","צור חשבון")</h1>
        <p class="text-center text-ink/50 mb-12">@L.T(HttpContext,"Self-register as a Client. Owner approves later.","הרשם כלקוח. הבעלים יאשר אחר כך.")</p>

        <div class="bg-black/[0.04] ring-1 ring-black/5 rounded-shell p-1.5 shadow-float">
            <div class="bg-paper-50 rounded-core shadow-inset p-8">
                <form method="post" class="space-y-4">
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Username","שם משתמש")</label>
                        <input asp-for="Username" autocomplete="username"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Password","סיסמה")</label>
                        <input asp-for="Password" type="password" autocomplete="new-password"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Email","אימייל")</label>
                        <input asp-for="Email" type="email" autocomplete="email"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Phone","טלפון")</label>
                        <input asp-for="Phone" type="tel" autocomplete="tel"
                               class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition" />
                    </div>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Account type","סוג חשבון")</label>
                        <select asp-for="BusinessType" id="bizSelect"
                                class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition">
                            <option value="Individual">@L.T(HttpContext,"Individual / Client (no VAT filing)","יחיד / לקוח (ללא דיווח מע״מ)")</option>
                            <option value="Patur">@L.T(HttpContext,"Osek Patur (VAT-exempt, ≤120k ₪/yr)","עוסק פטור (ללא מע״מ, עד 120k ₪/שנה)")</option>
                            <option value="Murshe">@L.T(HttpContext,"Osek Murshe (regular 18% VAT)","עוסק מורשה (מע״מ 18%)")</option>
                        </select>
                        <p class="text-xs text-ink/40 mt-2">
                            @L.T(HttpContext,"Patur invoices issue without 18% VAT. Murshe collects VAT on every sale (Form 836/874).",
                                              "עוסק פטור מנפיק חשבוניות ללא 18% מע״מ. עוסק מורשה גובה מע״מ על כל עסקה (טופס 836/874).")
                        </p>
                    </div>

                    <div id="zairWrap" class="hidden">
                        <label class="flex items-start gap-3 select-none cursor-pointer bg-paper-100/40 border border-black/5 rounded-2xl px-4 py-3">
                            <input asp-for="IsZair" type="checkbox" class="mt-1 accent-ink"/>
                            <span class="block">
                                <span class="block font-semibold text-ink">@L.T(HttpContext,"Claim Osek Zair income-tax status","סטטוס עוסק זעיר במס הכנסה")</span>
                                <span class="block text-xs text-ink/50 mt-1">
                                    @L.T(HttpContext,"Available if annual revenue ≤ ~122,833 ₪. Income tax is computed on 70% of revenue (flat 30% deemed-expenses, no receipts). Independent of VAT type.",
                                                      "זמין אם מחזור שנתי עד ~122,833 ₪. מס הכנסה מחושב על 70% מהמחזור (ניכוי הוצאות אוטומטי 30%, ללא קבלות). אינו משפיע על מעמד מע״מ.")
                                </span>
                            </span>
                        </label>
                    </div>

                    <script>
                        (function () {
                            var sel = document.getElementById('bizSelect');
                            var wrap = document.getElementById('zairWrap');
                            if (!sel || !wrap) return;
                            function sync() {
                                var v = sel.value;
                                if (v === 'Patur' || v === 'Murshe') wrap.classList.remove('hidden');
                                else wrap.classList.add('hidden');
                            }
                            sel.addEventListener('change', sync);
                            sync();
                        })();
                    </script>
                    <div>
                        <label class="pill text-ink/40 mb-2 block">@L.T(HttpContext,"Preferred currency","מטבע מועדף")</label>
                        <select asp-for="Currency"
                                class="w-full bg-paper-100/60 border border-black/5 rounded-2xl px-4 py-3 outline-none focus:border-accent transition">
                            <option>ILS</option>
                            <option>USD</option>
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <p class="text-rose text-sm">@Model.ErrorMessage</p>
                    }

                    <button type="submit"
                            class="group w-full inline-flex items-center justify-center gap-3 bg-ink text-paper-50 rounded-full px-6 py-3 mt-2 transition-all duration-500 ease-spring active:scale-[0.98]">
                        <span class="font-semibold">@L.T(HttpContext,"Create account","צור חשבון")</span>
                        <span class="w-7 h-7 rounded-full bg-white/15 flex items-center justify-center group-hover:translate-x-0.5 transition-all duration-500 ease-spring">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                        </span>
                    </button>
                </form>

                <p class="text-center text-xs text-ink/40 mt-6">
                    @L.T(HttpContext,"Already have an account?","יש לך חשבון?")
                    <a asp-page="/Login" class="text-accent hover:underline">@L.T(HttpContext,"Sign in","כניסה")</a>
                </p>
            </div>
        </div>
    </div>
</section>
